#!/usr/bin/env python3
"""
work-pack-build — assemble an XML review pack for /work.

Modes:
  plan      → context: arch docs + memory + journals + planning dir; no diff
  implement → context: relevant code + plan doc; with diff if present
  major-bug → context: failing test + relevant code + diff
  minor-bug → not invoked (no review)

Reads stdin / args, writes one XML file. Reviewer LLMs parse it.
Output goes to <out>/pack.xml (path printed on stdout).
"""

import argparse
import json
import os
import re
import subprocess
import sys
import xml.sax.saxutils as sx
from datetime import datetime, timezone
from pathlib import Path

HOME = Path.home()
MEMORY_DIR = HOME / ".claude/projects/-home-ubuntu/memory"
JOURNAL_DIR = HOME / ".claude/conversations"
MEMORY_INDEX = MEMORY_DIR / "MEMORY.md"

MAX_CTX_BYTES = 800_000  # cap pack size — reviewers have 1M+ ctx (Opus 4.7, Gemini 3.1 Pro, Kimi K2.6)
MAX_FILE_BYTES = 80_000  # per-file cap when including code (bumped 2026-04-28: 30K silently truncated 1432-LOC legacy files in plan reviews)
MAX_JOURNAL_ENTRIES = 5  # most recent entries from any matched journal


def esc(s: str) -> str:
    return sx.escape(s if isinstance(s, str) else str(s))


def cdata(s: str) -> str:
    """Wrap in CDATA, splitting if it contains the closing sequence."""
    if s is None:
        return ""
    s = str(s).replace("]]>", "]]]]><![CDATA[>")
    return f"<![CDATA[{s}]]>"


def run(cmd: list[str], check: bool = False, cwd: Path | None = None) -> str:
    """Run a command, return stdout. Empty string on failure unless check=True."""
    try:
        r = subprocess.run(
            cmd, capture_output=True, text=True, cwd=cwd, timeout=30, check=check
        )
        return r.stdout
    except Exception:
        if check:
            raise
        return ""


def keywords_from_task(task: str) -> list[str]:
    """Extract significant words from task text for grep matching."""
    # Drop common words; keep nouns/identifiers (anything ≥4 chars, alnum/_)
    stop = {
        "the", "and", "for", "with", "into", "from", "that", "this", "have",
        "been", "will", "should", "would", "could", "make", "need", "want",
        "feature", "task", "review", "implement", "build", "create", "fix",
        "bug", "issue", "code", "test", "tests", "work", "plan", "needs",
    }
    words = re.findall(r"[A-Za-z_][A-Za-z0-9_]{3,}", task.lower())
    seen, out = set(), []
    for w in words:
        if w in stop or w in seen:
            continue
        seen.add(w)
        out.append(w)
        if len(out) >= 8:
            break
    return out


def discover_memory_files(keywords: list[str], limit: int = 6) -> list[Path]:
    """Find memory files whose name OR description matches any keyword."""
    if not MEMORY_DIR.exists() or not keywords:
        return []
    matches: dict[Path, int] = {}
    for f in MEMORY_DIR.glob("*.md"):
        if f.name.startswith("_session_") or f.name == "MEMORY.md":
            continue
        score = 0
        name_lower = f.name.lower()
        for kw in keywords:
            if kw in name_lower:
                score += 3  # name match worth more
        # Read first 10 lines (frontmatter + first body line) for description match
        try:
            head = "\n".join(f.read_text(errors="replace").splitlines()[:10]).lower()
            for kw in keywords:
                if kw in head:
                    score += 1
        except Exception:
            pass
        if score > 0:
            matches[f] = score
    return [p for p, _ in sorted(matches.items(), key=lambda kv: -kv[1])[:limit]]


def discover_journals(keywords: list[str], limit: int = 3) -> list[tuple[Path, list[str]]]:
    """Find journals matching keywords; return (path, list-of-matching-entries)."""
    if not JOURNAL_DIR.exists() or not keywords:
        return []
    out = []
    for f in sorted(JOURNAL_DIR.glob("*.md")):
        try:
            text = f.read_text(errors="replace")
        except Exception:
            continue
        text_lower = text.lower()
        if not any(kw in text_lower for kw in keywords):
            continue
        # Extract matching entries (### blocks)
        entries = re.split(r"^### ", text, flags=re.MULTILINE)
        matching = []
        for e in entries[1:]:  # skip preamble
            e_lower = e.lower()
            if any(kw in e_lower for kw in keywords):
                # Title is the first line; truncate body
                lines = e.splitlines()
                title = lines[0]
                body = "\n".join(lines[1:])[:2000]
                matching.append(f"### {title}\n{body}")
        if matching:
            out.append((f, matching[:MAX_JOURNAL_ENTRIES]))
        if len(out) >= limit:
            break
    return out


def find_planning_dir(cwd: Path) -> Path | None:
    """Walk up from cwd looking for a planning/ directory."""
    p = cwd.resolve()
    while p != p.parent:
        cand = p / "planning"
        if cand.is_dir():
            return cand
        p = p.parent
    return None


def find_arch_docs(cwd: Path) -> list[Path]:
    """Locate CLAUDE.md, planning/CODING-PRINCIPLES.md, README.md, etc."""
    candidates = []
    p = cwd.resolve()
    while p != p.parent:
        for name in ("CLAUDE.md", "README.md"):
            f = p / name
            if f.is_file():
                candidates.append(f)
        for name in ("CODING-PRINCIPLES.md", "ARCHITECTURE.md", "PAGE-TEMPLATE.md"):
            f = p / "planning" / name
            if f.is_file():
                candidates.append(f)
        p = p.parent
    # de-dupe preserving order
    seen, out = set(), []
    for f in candidates:
        if f not in seen:
            seen.add(f)
            out.append(f)
    return out


def get_git_diff(ref: str | None) -> str:
    """Diff vs given ref or merge-base with main."""
    if ref:
        return run(["git", "diff", ref])
    base = run(["git", "merge-base", "HEAD", "main"]).strip() or \
           run(["git", "merge-base", "HEAD", "master"]).strip()
    if base:
        return run(["git", "diff", base])
    return run(["git", "diff", "HEAD"])


def get_changed_files(ref: str | None) -> list[Path]:
    """List of files changed in the working tree vs ref/main."""
    if ref:
        out = run(["git", "diff", "--name-only", ref])
    else:
        base = run(["git", "merge-base", "HEAD", "main"]).strip() or \
               run(["git", "merge-base", "HEAD", "master"]).strip()
        out = run(["git", "diff", "--name-only", base]) if base else \
              run(["git", "diff", "--name-only", "HEAD"])
    return [Path(p) for p in out.splitlines() if p.strip()]


def read_capped(p: Path, cap: int = MAX_FILE_BYTES) -> str:
    try:
        data = p.read_text(errors="replace")
    except Exception as e:
        return f"[unreadable: {e}]"
    if len(data) > cap:
        return data[:cap] + f"\n[... truncated, {len(data) - cap} bytes omitted]"
    return data


def emit_pack(args, ctx: dict) -> str:
    """Build the XML string."""
    parts = []
    parts.append('<?xml version="1.0" encoding="UTF-8"?>')
    parts.append(
        f'<review-pack mode="{esc(args.mode)}" round="{args.round}" '
        f'task-id="{esc(args.task_id)}" '
        f'created="{datetime.now(timezone.utc).isoformat()}">'
    )

    # ── ORDERING — critical for opencode reviewers ─────────────────────
    # OpenCode's `read` tool defaults to a 2000-line cap per call. Big packs
    # can run 4000-5000 lines. So review-critical sections (task, ask,
    # response-schema, relevant-code, diff) MUST be in the first ~2000 lines.
    # Reference context (arch_docs, planning, memory, journals) goes later
    # — reviewers who need it can do a second read with offset.
    #
    # Order:  task → ask → response-schema → relevant-code/diff/test →
    #         arch_docs → planning → memory → journals → prior-rounds →
    #         reviewer-instruction (truncation warning)

    # Task
    parts.append("  <task>")
    parts.append(f"    {cdata(args.task)}")
    parts.append("  </task>")

    # Ask — explicit instructions for the reviewer (small, always visible)
    ask = build_ask(args.mode, args.round)
    parts.append("  <ask>")
    parts.append(f"    {cdata(ask)}")
    parts.append("  </ask>")

    # Response schema — what the reviewer must return (small, always visible)
    parts.append("  <response-schema>")
    parts.append(f"    {cdata(RESPONSE_SCHEMA)}")
    parts.append("  </response-schema>")

    # Reviewer instruction injected ONLY when truncation fired. Moved to top
    # so opencode reviewers see it before being tempted to confabulate.
    if ctx.get("diff_truncated_from"):
        truncation_warning = (
            "The <diff> block was truncated to fit pack size. The full source files "
            "are included as <relevant-code><file> blocks below. For EVERY finding "
            "you report, verify the claim against the relevant <file> block — do "
            "NOT rely on the truncated diff alone. If a claim cannot be verified "
            "against a <file>, omit the finding rather than reporting a "
            "possibly-truncation-induced hallucination."
        )
        parts.append('  <reviewer-instruction priority="critical">')
        parts.append(f"    {cdata(truncation_warning)}")
        parts.append("  </reviewer-instruction>")

    # Context — review-target content (relevant code + diff + tests) FIRST
    parts.append("  <context>")

    # Relevant code (PRIMARY review target — must be visible to opencode)
    if ctx["code_files"]:
        parts.append("    <relevant-code>")
        for f in ctx["code_files"]:
            if not f.exists():
                continue
            parts.append(f'      <file path="{esc(str(f))}">{cdata(read_capped(f))}</file>')
        parts.append("    </relevant-code>")

    # Diff (PRIMARY for implement/major-bug)
    if ctx.get("diff"):
        truncated_from = ctx.get("diff_truncated_from")
        if truncated_from:
            parts.append(f'    <diff truncated="true" original-bytes="{truncated_from}" shown-bytes="{len(ctx["diff"])}">')
        else:
            parts.append("    <diff>")
        parts.append(f"      {cdata(ctx['diff'])}")
        parts.append("    </diff>")

    # Failing test (major-bug mode)
    if ctx.get("failing_test"):
        parts.append(f'    <failing-test path="{esc(ctx["failing_test"]["path"])}">')
        parts.append(f"      <test-code>{cdata(ctx['failing_test']['code'])}</test-code>")
        parts.append(f"      <test-output>{cdata(ctx['failing_test']['output'])}</test-output>")
        parts.append("    </failing-test>")

    # Architecture / coding-principle docs (REFERENCE — likely past line 2000)
    if ctx["arch_docs"]:
        parts.append("    <architecture-docs>")
        for f in ctx["arch_docs"]:
            parts.append(f'      <doc path="{esc(str(f))}">{cdata(read_capped(f))}</doc>')
        parts.append("    </architecture-docs>")

    # Planning docs (REFERENCE)
    if ctx["planning_docs"]:
        parts.append("    <planning-docs>")
        for f in ctx["planning_docs"]:
            parts.append(f'      <doc path="{esc(str(f))}">{cdata(read_capped(f, 200_000))}</doc>')
        parts.append("    </planning-docs>")

    # Related memory + journals — skipped on round 2+ (don't change between rounds)
    if args.round == 1:
        if ctx["memory_files"]:
            parts.append("    <related-memory>")
            for f in ctx["memory_files"]:
                parts.append(f'      <memory file="{esc(f.name)}">{cdata(read_capped(f, 5_000))}</memory>')
            parts.append("    </related-memory>")

        if ctx["journals"]:
            parts.append("    <related-journals>")
            for f, entries in ctx["journals"]:
                parts.append(f'      <journal name="{esc(f.stem)}" matched-entries="{len(entries)}">')
                for e in entries:
                    parts.append(f"        <entry>{cdata(e)}</entry>")
                parts.append("      </journal>")
            parts.append("    </related-journals>")
    else:
        skipped_count = len(ctx.get("memory_files") or []) + len(ctx.get("journals") or [])
        if skipped_count:
            parts.append(f'    <stable-context-skipped reason="round-{args.round}-no-change-since-round-1" '
                         f'memory-files-omitted="{len(ctx.get("memory_files") or [])}" '
                         f'journals-omitted="{len(ctx.get("journals") or [])}"/>')

    parts.append("  </context>")

    # Prior rounds (only present in round 2+) — moved to end since it grows
    # cumulatively. Reviewers needing it know to seek past line 2000.
    if args.prior_rounds_file and Path(args.prior_rounds_file).exists():
        parts.append("  <prior-rounds>")
        parts.append(f"    {cdata(Path(args.prior_rounds_file).read_text(errors='replace'))}")
        parts.append("  </prior-rounds>")

    parts.append("</review-pack>")
    return "\n".join(parts)


def build_ask(mode: str, round_n: int) -> str:
    base = (
        "Independently form your own conclusion. Do NOT anchor on any proposal "
        "in the pack — verify each claim against the source you are given. "
        "Use the <context> blocks for background; do your own discovery if needed.\n\n"
    )
    if mode == "plan":
        specific = (
            "PLAN MODE — review the proposed approach.\n"
            "  • Does the plan address the task?\n"
            "  • Does it respect the architecture docs and prior decisions in <related-memory>?\n"
            "  • Are there simpler/cheaper alternatives?\n"
            "  • What edge cases are missing?\n"
            "  • Risks not surfaced?\n"
        )
    elif mode == "implement":
        specific = (
            "IMPLEMENT MODE — review the code in <diff> against the plan in <planning-docs>.\n"
            "  • Does the diff implement the plan as agreed?\n"
            "  • Drift from the plan? If so, justified?\n"
            "  • Bugs, security issues, performance traps?\n"
            "  • Tests adequate?\n"
            "  • Style/architecture violations vs <architecture-docs>?\n"
        )
    elif mode == "major-bug":
        specific = (
            "MAJOR-BUG MODE — review the diagnosis AND the fix.\n"
            "  • Does the failing test in <failing-test> capture the actual bug?\n"
            "  • Is the proposed root cause correct, or a symptom?\n"
            "  • Will the fix in <diff> regress anything in <relevant-code>?\n"
            "  • Are tests sufficient (only the failing test, or are wider regressions possible)?\n"
        )
    else:
        specific = ""

    if round_n > 1:
        round_note = (
            f"\nROUND {round_n}: read <prior-rounds> first. Has the proposer addressed "
            "your previous findings? If yes, agree. If no, restate what's still wrong "
            "and why. Don't invent NEW critiques unless the revised proposal opened them.\n"
            "Note: <related-memory> and <related-journals> are intentionally omitted in "
            "round 2+ (they don't change between rounds — you saw them in round 1). "
            "If you genuinely need to re-check that context, ask in your verdict reasoning.\n"
        )
    else:
        round_note = ""

    return base + specific + round_note + (
        "\nReturn your response in EXACTLY the XML format under <response-schema>. "
        "End your file with a single line: ## DONE"
    )


RESPONSE_SCHEMA = """\
<findings>
  <finding severity="critical|high|medium|low" category="bug|security|architecture|performance|style|test|other">
    <claim>One-sentence description of the issue.</claim>
    <evidence>
      <file-path>relative/path/from/repo/root.ext</file-path>
      <line-number>42</line-number>
      <quoted-line><![CDATA[the EXACT line from the source file, verbatim, including all whitespace]]></quoted-line>
    </evidence>
    <suggestion>What you would do differently.</suggestion>
  </finding>
  <!-- repeat <finding> as needed; omit if nothing to flag -->
  <verdict agree="true|false|partial">
    <reasoning>One paragraph: why agree, why not, or what partial means.</reasoning>
  </verdict>
</findings>

## DONE

CRITICAL — self-consistency requirement:
For each <finding>, the <quoted-line> MUST be the verbatim line from the
source file you're citing — character-for-character, exactly as it appears.
The orchestrator runs an automated check that greps the source for that
quoted line. Findings whose quoted-line cannot be found in the cited file
are flagged as 'unverified' and DOWNGRADED in the quorum (likely
hallucination from over-eager review). If you cannot quote the exact line,
either re-read the source or omit the finding.
"""


def main():
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--mode", required=True, choices=["plan", "implement", "major-bug"])
    ap.add_argument("--task", required=True, help="task text (plan: feature description; implement: what was built; bug: bug description)")
    ap.add_argument("--task-id", required=True, help="stable task identifier (e.g. branch name)")
    ap.add_argument("--round", type=int, default=1)
    ap.add_argument("--out", required=True, help="output dir; pack written to <out>/pack.xml")
    ap.add_argument("--diff-ref", default=None, help="git ref for diff (default: merge-base with main)")
    ap.add_argument("--prior-rounds-file", default=None, help="path to a markdown file containing prior rounds' summaries")
    ap.add_argument("--planning-doc", default=None, help="explicit path to the plan doc to include")
    ap.add_argument("--failing-test", default=None, help="path to the failing test file (major-bug mode)")
    ap.add_argument("--failing-test-output", default=None, help="path to file with the failing test's output")
    ap.add_argument("--extra-files", default="", help="comma-separated extra files to include in <relevant-code>")
    args = ap.parse_args()

    cwd = Path.cwd()
    out_dir = Path(args.out)
    out_dir.mkdir(parents=True, exist_ok=True)

    # Build context dict
    keywords = keywords_from_task(args.task)
    ctx = {
        "arch_docs": find_arch_docs(cwd) if args.mode == "plan" else find_arch_docs(cwd)[:2],
        "planning_docs": [],
        "memory_files": discover_memory_files(keywords),
        "journals": discover_journals(keywords),
        "code_files": [],
        "diff": "",
    }

    # Mode-specific augmentation
    if args.planning_doc and Path(args.planning_doc).exists():
        ctx["planning_docs"].append(Path(args.planning_doc))
    elif args.mode == "plan":
        # Pull recently-modified planning docs from planning/ dir
        plan_dir = find_planning_dir(cwd)
        if plan_dir:
            recents = sorted(plan_dir.glob("*.md"), key=lambda p: -p.stat().st_mtime)[:3]
            ctx["planning_docs"].extend(recents)

    if args.mode in ("implement", "major-bug"):
        ctx["diff"] = get_git_diff(args.diff_ref)
        # Code context = changed files (capped by size)
        for f in get_changed_files(args.diff_ref):
            if f.exists() and f.suffix in (".py", ".ts", ".tsx", ".js", ".jsx", ".sql", ".go", ".rs", ".sh", ".bash"):
                ctx["code_files"].append(f)
            if len(ctx["code_files"]) >= 10:
                break

    if args.mode == "major-bug" and args.failing_test:
        test_path = Path(args.failing_test)
        if test_path.exists():
            output = ""
            if args.failing_test_output and Path(args.failing_test_output).exists():
                output = Path(args.failing_test_output).read_text(errors="replace")[:10_000]
            ctx["failing_test"] = {
                "path": str(test_path),
                "code": read_capped(test_path),
                "output": output,
            }

    if args.extra_files:
        for raw in args.extra_files.split(","):
            p = Path(raw.strip())
            if p.exists() and p not in ctx["code_files"]:
                ctx["code_files"].append(p)

    # Build XML
    xml = emit_pack(args, ctx)

    # Cap total size — drop journals first, then memory, if we exceed
    if len(xml) > MAX_CTX_BYTES:
        ctx["journals"] = ctx["journals"][:1]
        xml = emit_pack(args, ctx)
    if len(xml) > MAX_CTX_BYTES:
        ctx["memory_files"] = ctx["memory_files"][:2]
        xml = emit_pack(args, ctx)
    if len(xml) > MAX_CTX_BYTES:
        # Last resort: truncate diff. Record original size so emit_pack can
        # warn the reviewer to cross-check code_files instead of trusting
        # the truncated diff (saw gem-1 hallucinate findings from anchor-bias
        # on a 50KB-truncated diff while ignoring full <code_files> blocks).
        if ctx.get("diff"):
            ctx["diff_truncated_from"] = len(ctx["diff"])
            ctx["diff"] = ctx["diff"][:50_000] + "\n[diff truncated for size]"
            xml = emit_pack(args, ctx)

    pack_path = out_dir / "pack.xml"
    pack_path.write_text(xml)

    print(json.dumps({
        "pack": str(pack_path),
        "bytes": len(xml),
        "context": {
            "arch_docs": [str(p) for p in ctx["arch_docs"]],
            "planning_docs": [str(p) for p in ctx["planning_docs"]],
            "memory_files": [p.name for p in ctx["memory_files"]],
            "journals": [p[0].stem for p in ctx["journals"]],
            "code_files": [str(p) for p in ctx["code_files"]],
            "diff_bytes": len(ctx.get("diff") or ""),
            "keywords_used": keywords,
        },
    }, indent=2))


if __name__ == "__main__":
    main()
