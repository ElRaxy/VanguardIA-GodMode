#!/usr/bin/env bash
# work — multi-LLM workflow orchestrator with lineage-weighted quorum.
#
# This tool is the executor. The /work SLASH COMMAND drives it from Claude Code.
# It does ONE phase at a time (called by Claude as needed). It does NOT loop
# end-to-end on its own — Claude is the conductor.
#
# Subcommands:
#   work pick-agents [--exclude <a,b>]
#       → picks 1 codex + 1 gemini + 1 opencode (LRU-rotated). Prints JSON.
#
#   work review --mode plan|implement|major-bug --task "..." --task-id <id>
#               --round <N> [--planning-doc <path>] [--failing-test <path>]
#               [--failing-test-output <path>] [--diff-ref <ref>]
#               [--prior-rounds-file <path>] [--extra-files a,b,c]
#               [--agents <a,b,c>] [--out <dir>] [--timeout <sec>]
#       → builds XML pack, decides /clear (vs last task), nudges agents,
#         BLOCKS on inotifywait until all reviewers write `## DONE`,
#         runs work-converge, prints JSON with decision + per-agent findings.
#
#   work state-get
#       → prints ~/.work/state.json
#
#   work state-set --task-id <id>
#       → records last task; subsequent `work review` will diff against this
#         to decide whether to /clear reviewer context.
#
#   work clean [--older-than <days>] [--dry-run]
#       → purges /tmp/work-* dirs older than N days (default 7).
#         Use --dry-run to preview without deleting.
#
# State file: ~/.work/state.json
#   { "last_task_id": "...", "last_round": {...}, "last_agents": [...] }

set -euo pipefail

AGENTS_JSON="$HOME/.config/agent-sessions/agents.json"
STATE_DIR="$HOME/.work"
STATE_FILE="$STATE_DIR/state.json"
LRU_FILE="$STATE_DIR/agent-lru.json"
sudo mkdir -p "$STATE_DIR" 2>/dev/null || mkdir -p "$STATE_DIR"
sudo chown -R ubuntu:ubuntu "$STATE_DIR" 2>/dev/null || true
[ -f "$STATE_FILE" ] || echo '{}' > "$STATE_FILE"
[ -f "$LRU_FILE"   ] || echo '{}' > "$LRU_FILE"

[ -f "$AGENTS_JSON" ] || { echo "work: missing $AGENTS_JSON" >&2; exit 1; }
# inotifywait is required only by `work review`; checked inside cmd_review.

# ── pick-agents subcommand ───────────────────────────────────────────────
cmd_pick_agents() {
  local exclude=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --exclude) exclude="$2"; shift 2 ;;
      *) echo "work pick-agents: unknown flag $1" >&2; exit 2 ;;
    esac
  done

  # For each lineage, pick the alive agent with the oldest last_used_at (LRU).
  python3 - <<PYEOF
import json, subprocess, sys
from pathlib import Path

agents = json.loads(Path("$AGENTS_JSON").read_text())["agents"]
lru = json.loads(Path("$LRU_FILE").read_text())
exclude = set("$exclude".split(",")) if "$exclude" else set()

# Check tmux liveness
def alive(session):
    r = subprocess.run(["tmux", "has-session", "-t", session],
                       capture_output=True)
    return r.returncode == 0

picked = {}
for lineage in ("codex", "gemini", "opencode"):
    pool = [
        a for a in agents
        if a["type"] == lineage
        and a["name"] not in exclude
        and alive(a["tmux_session"])
    ]
    if not pool:
        print(json.dumps({"error": f"no alive {lineage} agent available",
                          "exclude": list(exclude)}), file=sys.stderr)
        sys.exit(1)
    # Sort by (priority asc, last_used_at asc).
    # Lower priority number = preferred. Default 100 if unset.
    # Within same priority, LRU wins (oldest used first).
    pool.sort(key=lambda a: (
        a.get("priority", 100),
        lru.get(a["name"], "1970-01-01T00:00:00Z"),
    ))
    picked[lineage] = pool[0]["name"]

print(json.dumps(picked, indent=2))
PYEOF
}

# ── state-get subcommand ─────────────────────────────────────────────────
cmd_state_get() {
  cat "$STATE_FILE"
}

# ── clean subcommand ─────────────────────────────────────────────────────
cmd_clean() {
  local days=7 dry=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --older-than) days="$2"; shift 2 ;;
      --dry-run)    dry=1; shift ;;
      *) echo "work clean: unknown flag $1" >&2; exit 2 ;;
    esac
  done

  # Find /tmp/work-* dirs older than $days days (mtime), print + optionally rm
  local found=0 freed=0
  while IFS= read -r d; do
    [ -d "$d" ] || continue
    local sz_kb
    sz_kb=$(du -sk "$d" 2>/dev/null | awk '{print $1}')
    found=$((found + 1))
    freed=$((freed + sz_kb))
    if [ "$dry" -eq 1 ]; then
      printf '  (dry) %s  (%d KB)\n' "$d" "$sz_kb"
    else
      printf '  rm    %s  (%d KB)\n' "$d" "$sz_kb"
      rm -rf -- "$d"
    fi
  done < <(find /tmp -maxdepth 1 -type d -name 'work-*' -mtime "+$days" 2>/dev/null)

  if [ "$found" -eq 0 ]; then
    echo "no /tmp/work-* dirs older than ${days}d"
  else
    if [ "$dry" -eq 1 ]; then
      echo "▶ ${found} dir(s), ~$((freed / 1024)) MB would be freed (dry run)"
    else
      echo "▶ removed ${found} dir(s), freed ~$((freed / 1024)) MB"
    fi
  fi
}

# ── state-set subcommand ─────────────────────────────────────────────────
cmd_state_set() {
  local task_id=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --task-id) task_id="$2"; shift 2 ;;
      *) echo "work state-set: unknown flag $1" >&2; exit 2 ;;
    esac
  done
  [ -z "$task_id" ] && { echo "work state-set: --task-id required" >&2; exit 2; }
  python3 - <<PYEOF
import json
from pathlib import Path
s = json.loads(Path("$STATE_FILE").read_text() or "{}")
s["last_task_id"] = "$task_id"
Path("$STATE_FILE").write_text(json.dumps(s, indent=2))
PYEOF
}

# ── review subcommand (the main event) ───────────────────────────────────
cmd_review() {
  command -v inotifywait >/dev/null || {
    echo "work review: inotifywait required (sudo apt install inotify-tools)" >&2
    exit 1
  }
  local mode="" task="" task_id="" round=1 out=""
  local planning_doc="" failing_test="" failing_test_output=""
  local diff_ref="" prior_rounds_file="" extra_files=""
  # 10-minute hard cap. Anything longer wastes Claude's context on stale waits.
  # Override per-call with --timeout <sec> if a specific review needs more.
  local agents="" timeout=600

  while [ $# -gt 0 ]; do
    case "$1" in
      --mode)                mode="$2"; shift 2 ;;
      --task)                task="$2"; shift 2 ;;
      --task-id)             task_id="$2"; shift 2 ;;
      --round)               round="$2"; shift 2 ;;
      --out)                 out="$2"; shift 2 ;;
      --planning-doc)        planning_doc="$2"; shift 2 ;;
      --failing-test)        failing_test="$2"; shift 2 ;;
      --failing-test-output) failing_test_output="$2"; shift 2 ;;
      --diff-ref)            diff_ref="$2"; shift 2 ;;
      --prior-rounds-file)   prior_rounds_file="$2"; shift 2 ;;
      --extra-files)         extra_files="$2"; shift 2 ;;
      --agents)              agents="$2"; shift 2 ;;
      --timeout)             timeout="$2"; shift 2 ;;
      *) echo "work review: unknown flag $1" >&2; exit 2 ;;
    esac
  done

  [ -z "$mode" ]    && { echo "work review: --mode required" >&2; exit 2; }
  [ -z "$task" ]    && { echo "work review: --task required" >&2; exit 2; }
  [ -z "$task_id" ] && { echo "work review: --task-id required" >&2; exit 2; }

  # Auto-pick agents if not provided
  if [ -z "$agents" ]; then
    local picks
    picks=$(cmd_pick_agents) || { echo "$picks" >&2; exit 2; }
    agents=$(echo "$picks" | python3 -c 'import json,sys; d=json.load(sys.stdin); print(",".join(d.values()))')
  fi

  # Default out dir
  ts="$(date +%Y%m%d-%H%M%S)"
  [ -z "$out" ] && out="/tmp/work-${task_id//\//-}-r${round}-$ts"
  mkdir -p "$out"

  # Decide: should we /clear first? (different task_id from last invocation)
  local last_task_id
  last_task_id=$(python3 -c 'import json; print(json.load(open("'"$STATE_FILE"'")).get("last_task_id",""))')
  local clear_first=0
  if [ -n "$last_task_id" ] && [ "$last_task_id" != "$task_id" ]; then
    clear_first=1
  fi

  # Build pack
  local pack_args=(
    --mode "$mode"
    --task "$task"
    --task-id "$task_id"
    --round "$round"
    --out "$out"
  )
  [ -n "$planning_doc" ]         && pack_args+=(--planning-doc "$planning_doc")
  [ -n "$failing_test" ]         && pack_args+=(--failing-test "$failing_test")
  [ -n "$failing_test_output" ]  && pack_args+=(--failing-test-output "$failing_test_output")
  [ -n "$diff_ref" ]             && pack_args+=(--diff-ref "$diff_ref")
  [ -n "$prior_rounds_file" ]    && pack_args+=(--prior-rounds-file "$prior_rounds_file")
  [ -n "$extra_files" ]          && pack_args+=(--extra-files "$extra_files")

  local pack_meta
  pack_meta=$($HOME/.local/bin/work-pack-build "${pack_args[@]}") || {
    echo "work: pack build failed" >&2; exit 1
  }
  local pack_path
  pack_path=$(echo "$pack_meta" | python3 -c 'import json,sys; print(json.load(sys.stdin)["pack"])')
  echo "$pack_meta" > "$out/pack-meta.json"

  echo "▶ Mode: $mode  |  Task: $task_id  |  Round: $round" >&2
  echo "▶ Agents: $agents" >&2
  echo "▶ Pack: $pack_path ($(wc -c <"$pack_path") bytes)" >&2
  echo "▶ Out:  $out" >&2
  [ "$clear_first" -eq 1 ] && echo "▶ /clear: ON (task_id changed: '$last_task_id' → '$task_id')" >&2
  [ "$clear_first" -eq 0 ] && [ -n "$last_task_id" ] && echo "▶ /clear: OFF (same task as last: $task_id)" >&2

  # Resolve agents → tmux sessions, nudge commands, types
  IFS=',' read -ra AGENT_LIST <<<"$agents"
  declare -A NUDGE ENVVAR SESS TYPE
  VALID=()
  for raw in "${AGENT_LIST[@]}"; do
    name="${raw// /}"
    row=$(jq -c --arg n "$name" '.agents[] | select(.name == $n)' "$AGENTS_JSON")
    [ -z "$row" ] && { echo "  ✗ $name not in agents.json (skipping)" >&2; continue; }
    NUDGE[$name]=$(jq -r '.nudge_command' <<<"$row")
    ENVVAR[$name]=$(jq -r '.tmux_env_var' <<<"$row")
    SESS[$name]=$(jq -r '.tmux_session' <<<"$row")
    TYPE[$name]=$(jq -r '.type' <<<"$row")
    if ! tmux has-session -t "${SESS[$name]}" 2>/dev/null; then
      echo "  ✗ $name tmux session ${SESS[$name]} not alive (skipping)" >&2
      continue
    fi
    VALID+=("$name")
  done
  [ ${#VALID[@]} -eq 0 ] && { echo "work: no usable agents" >&2; exit 1; }

  # Clear policy:
  #   • ALL agents: clear when task_id changed (clear_first=1) — different work entirely.
  #   • OPENCODE agents (kimi/deepseek): ALWAYS clear, even within same task / same round.
  #     Reason: opencode TUIs preserve conversation history across nudges, which causes
  #     the reviewer to drift conversational ("what would you like me to do with this?")
  #     instead of treating each nudge as a fresh directive. Cross-round context is
  #     preserved via <prior-rounds> in the XML pack, NOT via session memory.
  #   • Codex + Gemini: respect clear_first only — they're directive enough to handle
  #     in-session context without drifting.
  #
  # Per-CLI command:
  #   • Codex + Gemini → /clear
  #   • Opencode      → /new (opencode doesn't have /clear, /new starts a fresh session)
  clear_cmd_for() {
    case "$1" in
      opencode) echo "/new" ;;
      *)        echo "/clear" ;;
    esac
  }
  for name in "${VALID[@]}"; do
    needs_clear=0
    [ "$clear_first" -eq 1 ] && needs_clear=1
    [ "${TYPE[$name]}" = "opencode" ] && needs_clear=1
    if [ "$needs_clear" -eq 1 ]; then
      reason="task changed"
      [ "$clear_first" -eq 0 ] && reason="opencode always-clear"
      cmd=$(clear_cmd_for "${TYPE[$name]}")
      echo "  ⌫ $cmd → $name ($reason)" >&2
      tmux send-keys -t "${SESS[$name]}" "$cmd" Enter 2>/dev/null || true
      sleep 1
    fi
  done
  # Brief settle if anything was cleared
  if [ "$clear_first" -eq 1 ] || [ "${#VALID[@]}" -gt 0 ]; then
    # Only settle if at least one opencode or task changed
    for name in "${VALID[@]}"; do
      if [ "${TYPE[$name]}" = "opencode" ] || [ "$clear_first" -eq 1 ]; then
        sleep 2
        break
      fi
    done
  fi

  # Send the nudge to each agent
  for name in "${VALID[@]}"; do
    out_file="$out/${name}-findings.md"

    # Per-CLI prompt format. Each TUI handles multi-line input differently:
    #   • Codex: bracketed-paste safe, multi-line OK, parses paths verbatim.
    #   • Gemini: each \n inside the input box is treated as Submit — a multi-
    #     paragraph paste gets fired as 8 separate one-line queries, with
    #     only the last paragraph landing in the input box. MUST be single-
    #     line, and uses @<abs-path> syntax for inline file attach.
    #   • Opencode: multi-line OK with bracketed paste, but tends to drift
    #     conversational without an explicit "begin immediately" directive.
    case "${TYPE[$name]}" in
      gemini)
        # Single line — no \n anywhere. @-attach reads the pack file inline,
        # bypassing any need for the agent to call ReadFile itself.
        prompt="Review @${pack_path} — read the <ask> and <response-schema> blocks, then write the XML findings to ${out_file} using your write_file tool (NOT cat/echo/tee/printf, which prompt for shell permission). End the file with a single line: ## DONE — without it the orchestrator hangs. Begin immediately, do NOT ask clarifying questions."
        ;;
      opencode)
        # Single line — no \n, no leading '/' or '@'. tmux paste-buffer splits
        # large pastes into ~1.5KB chunks; any '/' or '@' at a chunk boundary
        # opens opencode's slash-command or agent-picker mid-paste, swallowing
        # the rest of the prompt (saw this with deepseek showing "Select agent").
        # Plain prose with absolute paths embedded mid-sentence avoids both.
        # Note: opencode's read tool defaults to 2000 lines/call. Packs run
        # 4000-5000 lines, so explicitly tell the reviewer to use limit:5000
        # OR read the whole file. Pack is also ordered with critical content
        # at the top (task → ask → schema → relevant-code), but we still nudge.
        prompt="Round $round reviewer: read the ENTIRE XML pack at ${pack_path} — your read tool may default to 2000 lines per call but this pack can run 4000-5000 lines, so call read with limit set high (e.g. limit: 6000) OR read in chunks (offset 0, then offset 2000, then offset 4000) to ensure you see the full pack including <relevant-code> and <response-schema>. The pack starts with <task>, <ask>, <response-schema> at the top; the source files you must verify findings against are in <relevant-code><file>...</file> blocks inside <context>. Use your write_file tool (NOT cat or echo or tee or printf, which prompt for shell permission) to write your XML findings to ${out_file}, ending the file with a single line containing exactly: ## DONE — without that the orchestrator hangs. Begin immediately, do NOT ask clarifying questions, do NOT respond conversationally."
        ;;
      *)
        # Codex (default) — multi-line is fine.
        prompt="Please review the XML context pack at: $pack_path

Read it carefully — the <ask> block tells you what to do, the <response-schema> block tells you the EXACT XML format to return.

When you finish, write your full response to: $out_file

CRITICAL — to avoid permission prompts:
  • Use your file-write tool (write_file / edit / Write) to create the findings file.
  • Do NOT use shell commands like 'cat <<EOF >file', 'echo >file', 'tee', or 'printf >file' — those are 'shell' tools that prompt for permission and will block this orchestrator.
  • If your CLI only has shell, that's OK — just answer the permission prompt yourself; the orchestrator will detect and auto-approve safe writes.

End your file with a single line containing exactly: ## DONE

Failure to end with '## DONE' will leave the orchestrator hanging — please double-check before stopping."
        ;;
    esac

    printf '# Findings — %s\n\n_(in progress, started %s)_\n' "$name" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$out_file"
    echo "→ nudging $name (tmux ${SESS[$name]})" >&2
    LAST_PROMPT[$name]="$prompt"
    LAST_NUDGE[$name]="${NUDGE[$name]}"
    LAST_NUDGE_ENV[$name]="${ENVVAR[$name]}"
    ERROR_RETRIED_AT[$name]=0
    ERROR_GAVE_UP[$name]=0
    # Pre-flight Escape on opencode: kills any stale modal popup (Select agent,
    # Select model, error toast) left over from a previous interrupted nudge.
    # Cheap, idempotent, no effect if no modal is showing.
    if [ "${TYPE[$name]}" = "opencode" ]; then
      tmux send-keys -t "${SESS[$name]}" Escape 2>/dev/null || true
      sleep 0.3
      tmux send-keys -t "${SESS[$name]}" Escape 2>/dev/null || true
      sleep 0.3
    fi
    env "${ENVVAR[$name]}=${SESS[$name]}" "${NUDGE[$name]}" "$prompt" >/dev/null

    # Update LRU
    python3 - <<PYEOF
import json, datetime
from pathlib import Path
lru = json.loads(Path("$LRU_FILE").read_text() or "{}")
lru["$name"] = datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")
Path("$LRU_FILE").write_text(json.dumps(lru, indent=2))
PYEOF
  done

  # ── Wait for ALL findings files to end with `## DONE` ──────────────────
  # Strategy: blocking inotifywait → zero CPU, zero token burn during wait.
  # Re-check after each filesystem event. Hard cap: $timeout seconds.
  echo "▶ Waiting for ${#VALID[@]} reviewer(s) to write '## DONE' (zero-poll, event-driven)" >&2

  local start now elapsed
  start=$(date +%s)
  while :; do
    local done_count=0
    for name in "${VALID[@]}"; do
      if tail -3 "$out/${name}-findings.md" 2>/dev/null | grep -qE '^## DONE\s*$'; then
        done_count=$((done_count + 1))
      fi
    done

    if [ "$done_count" -eq "${#VALID[@]}" ]; then
      break
    fi

    now=$(date +%s); elapsed=$((now - start))
    if [ "$elapsed" -ge "$timeout" ]; then
      echo "  ✗ TIMEOUT after ${elapsed}s ($done_count/${#VALID[@]} done)" >&2
      break
    fi

    # Check for permission prompts, modal popups, and provider errors in any
    # reviewer pane. Order matters: dismiss popups first (cheapest fix), then
    # auto-approve safe perm prompts, then handle provider errors.
    for name in "${VALID[@]}"; do
      check_for_popups "$name" >&2
      check_and_approve_prompts "$name" >&2
      check_for_errors "$name" >&2
    done

    # Block until ANY findings file changes (or timeout). 5s safety wake to
    # re-check permission prompts AND provider errors — catches stuck-on-prompt
    # or errored reviewers fast (was 15s, was 60s before that).
    inotifywait -qq -e modify -e create "$out/" --timeout 5 2>/dev/null || true
  done

  echo "  ✓ All ${done_count}/${#VALID[@]} reviewers done in ${elapsed}s" >&2

  # ── Run convergence check ─────────────────────────────────────────────
  local converge_json
  converge_json=$($HOME/.local/bin/work-converge --out-dir "$out" --agents "$agents" 2>&1) || {
    # Non-zero exit codes are fine (1 = disagree, 2 = incomplete) — we still want the JSON
    :
  }

  echo "$converge_json" > "$out/converge.json"

  # Update state
  python3 - <<PYEOF
import json
from pathlib import Path
s = json.loads(Path("$STATE_FILE").read_text() or "{}")
s["last_task_id"] = "$task_id"
s.setdefault("last_round", {})["$task_id"] = $round
s["last_agents"] = "$agents".split(",")
Path("$STATE_FILE").write_text(json.dumps(s, indent=2))
PYEOF

  # Print the converge JSON to stdout (Claude consumes this)
  echo "$converge_json"

  # Exit code mirrors converge: 0 agree, 1 disagree, 2 incomplete
  local decision
  decision=$(echo "$converge_json" | python3 -c 'import json,sys; print(json.load(sys.stdin)["decision"])' 2>/dev/null || echo "incomplete")
  case "$decision" in
    agree) exit 0 ;;
    disagree) exit 1 ;;
    *) exit 2 ;;
  esac
}

# ── Permission prompt detection — second line of defense ────────────────
# First line: CLI configs (gemini auto_edit, opencode read/edit=allow,
# codex sandbox-write). This guard is for prompts that escape those defaults
# (e.g. shell commands like cat/tee that gemini/opencode treat as "shell").
PROMPT_RE='Allow this|Allow execution|Allow for this session|Allow once|Allow always|Approve this|Run this command\?|Proceed\?|Confirm \(y/N\)|\[y/N\]|\(y/n\)|◐ accept|❯ Yes|Apply this|Execute this|Allow \[|Permission required|Access external'

# Numbered-prompt detection (gemini): "1. Allow once / 2. Allow for this session / 3. No"
NUMBERED_PROMPT_RE='Allow for this session|1\.[ \t]+Allow once'

# Opencode arrow-key prompt: "Allow once   Allow always   Reject" with cursor.
# Default is "Allow once" highlighted — Enter accepts that. To accept "Allow
# always" (avoid re-prompt on same path), need Right-Arrow + Enter. We pick
# "Allow always" to minimize re-prompts during a multi-round review.
OPENCODE_PROMPT_RE='Allow once[ \t]+Allow always[ \t]+Reject'

# Destructive — NEVER auto-approve. Agent stays stuck so user sees it.
DESTRUCTIVE_RE='\brm -rf\b|\brm -fr\b|\brm +-r +-f\b|\bsudo\b|\bDROP +TABLE\b|\bTRUNCATE\b|\bgit +push +.*--force\b|\bgit +push +-f\b|\bgit +reset +--hard\b|\bgit +checkout +\.\b|\bgit +clean +-[fdx]\b|\bDELETE +FROM\b|\bdd +if=\b|>\s*/dev/(sd|nvme|hd|xvd)|\bmkfs\b|\biptables +-F\b|\bkill +-9 +1\b|:\(\)\{:\|:&\};:|\|\s*(sh|bash|zsh)\s*$|curl[^|]*\|\s*(sh|bash)|wget[^|]*\|\s*(sh|bash)|\beval\s+\$\(|--no-verify|--no-gpg-sign|chmod +(-R +)?777|chown +-R\b|\bcrontab +-r\b|\bshutdown\b|\breboot\b|\bsystemctl +(stop|disable|mask)\b|\bdocker +(rm|kill) +-f\b|>\s*/etc/'

declare -A APPROVED_AT
declare -A DESTRUCTIVE_FLAGGED

# Provider/transport errors surfaced by reviewer TUIs (opencode toast,
# gemini inline, codex inline). Distinct from permission prompts — these
# mean the upstream LLM call failed (rate limit, gateway hiccup, context
# overflow). Policy: retry once, then give up and let timeout fire.
ERROR_RE='Error from provider|Provider returned error|rate limit (reached|exceeded)|429 Too Many|503 Service|502 Bad Gateway|context (length|window) exceeded|context_length_exceeded|API request failed|Connection (closed|refused|reset)|ECONNRESET|Too Many Requests|insufficient quota|payment required|model overloaded|service unavailable|Request timed out|fetch failed'

declare -A LAST_PROMPT       # agent -> prompt text (for retry)
declare -A LAST_NUDGE        # agent -> nudge command path
declare -A LAST_NUDGE_ENV    # agent -> tmux-session env var name
declare -A ERROR_RETRIED_AT  # agent -> unix ts of retry (0 = none yet)
declare -A ERROR_GAVE_UP     # agent -> 1 if 2nd error fired
declare -A SWAPPED_TO        # agent -> partner we swapped IN as replacement
declare -A POPUP_DISMISSED_AT # agent -> last unix ts we sent Escape

# Per-lineage peer-swap on persistent error. When an agent fails (provider
# error, rate limit, repeat popup), find the next alive agent of the SAME
# lineage from agents.json and swap it in. Replaces the old hardcoded
# OPENCODE_PARTNER map — works for codex (cdx-1→2→3), gemini (gem-1→2→…),
# and opencode (kimi→deepseek and reverse).
declare -A SWAP_TRIED  # "agent_failed" -> "agent_tried_as_replacement"

# Modal popups that opencode raises mid-flight (Select agent / Select model
# triggered by stray @ or / in pasted prompt; "No results found" Ask popup).
# These block the TUI until Escape is pressed — orchestrator must dismiss
# them or the agent never sees the prompt.
OPENCODE_POPUP_RE='Select agent|Select model|Select session|^[[:space:]]*Ask[[:space:]]+No results found'

check_and_approve_prompts() {
  local name="$1"
  local sess="${SESS[$name]:-}"
  [ -z "$sess" ] && return 0
  local pane
  pane=$(tmux capture-pane -t "$sess" -p 2>/dev/null | tail -30 || true)
  echo "$pane" | grep -qiE "$PROMPT_RE" || return 0

  if echo "$pane" | grep -qiE "$DESTRUCTIVE_RE"; then
    # Only print once per agent (don't spam the log)
    if [ "${DESTRUCTIVE_FLAGGED[$name]:-0}" != "1" ]; then
      DESTRUCTIVE_FLAGGED[$name]=1
      printf '  🛑 %-12s DESTRUCTIVE prompt detected — REFUSING auto-approve. Attach session to inspect.\n' "$name" >&2
      printf '  🛑 %-12s tmux attach -t %s\n' "$name" "$sess" >&2
      # Write a flag file the slash command can surface
      echo "$name: $(date -Iseconds): destructive prompt blocked" >> "$out/destructive-blocks.log" 2>/dev/null || true
    fi
    return 0
  fi

  local now last
  now=$(date +%s)
  last="${APPROVED_AT[$name]:-0}"
  [ $((now - last)) -lt 30 ] && return 0
  APPROVED_AT[$name]=$now

  # Log the request line(s) so the user can see WHAT was approved and decide
  # whether to permanently allow it via CLI config (codex trust / gemini
  # policy / opencode permission). Heuristic: capture the line with the
  # command/tool name (often above the Allow/Approve line).
  local approved_cmd
  approved_cmd=$(echo "$pane" | grep -iE 'tool:|command:|run:|^[[:space:]]*\$|Bash\s*\(|shell\s*:' | tail -1 | tr -s ' ' | cut -c1-200)
  [ -z "$approved_cmd" ] && approved_cmd="(command line not captured — see tmux scrollback)"
  echo "$(date -Iseconds)	$name	$approved_cmd" >> "$out/approvals.log" 2>/dev/null || true
  echo "$(date -Iseconds)	$name	$approved_cmd" >> "$HOME/.work/approvals-global.log" 2>/dev/null || true

  # Three prompt formats — pick the right keystrokes:
  if echo "$pane" | grep -qE "$OPENCODE_PROMPT_RE"; then
    # Opencode arrow-key prompt: cursor on "Allow once", we want "Allow always".
    # Send Right-Arrow + Enter.
    printf '  ↩ %-12s opencode prompt — auto-approving (Right + Enter = Allow always)\n' "$name" >&2
    tmux send-keys -t "$sess" Right Enter 2>/dev/null || true
  elif echo "$pane" | grep -qiE "$NUMBERED_PROMPT_RE"; then
    # Gemini numbered prompt — send "2" (Allow for this session).
    printf '  ↩ %-12s gemini numbered prompt — auto-approving (2 = Allow for session)\n' "$name" >&2
    tmux send-keys -t "$sess" "2" Enter 2>/dev/null || true
  else
    # Codex-style y/n.
    printf '  ↩ %-12s safe prompt — auto-approving (y + Enter)\n' "$name" >&2
    tmux send-keys -t "$sess" "y" Enter 2>/dev/null || true
  fi
}

# ── Opencode modal-popup dismissal ──────────────────────────────────────
# When opencode TUI shows a "Select agent" / "Select model" picker (triggered
# by an @ or / character in the pasted prompt mid-bracketed-paste-split),
# the input box is blocked until Escape. Without dismissal the nudge text
# is lost and the agent never starts reviewing.
check_for_popups() {
  local name="$1"
  [ "${TYPE[$name]:-}" != "opencode" ] && return 0
  local sess="${SESS[$name]:-}"
  [ -z "$sess" ] && return 0
  local pane
  pane=$(tmux capture-pane -t "$sess" -p 2>/dev/null | tail -30 || true)
  echo "$pane" | grep -qE "$OPENCODE_POPUP_RE" || return 0

  local now last
  now=$(date +%s)
  last="${POPUP_DISMISSED_AT[$name]:-0}"
  # Debounce: don't keep mashing Escape on the same popup frame
  [ $((now - last)) -lt 10 ] && return 0
  POPUP_DISMISSED_AT[$name]=$now

  printf '  ⌫ %-12s opencode modal popup detected — dismissing (Escape×2)\n' "$name" >&2
  tmux send-keys -t "$sess" Escape 2>/dev/null || true
  sleep 0.5
  tmux send-keys -t "$sess" Escape 2>/dev/null || true
  echo "$name: $(date -Iseconds): popup dismissed" >> "$out/popup-dismissals.log" 2>/dev/null || true

  # Re-nudge so the original prompt actually reaches the TUI (the popup ate it).
  if [ -n "${LAST_PROMPT[$name]:-}" ]; then
    sleep 1
    env "${LAST_NUDGE_ENV[$name]}=${SESS[$name]}" "${LAST_NUDGE[$name]}" "${LAST_PROMPT[$name]}" >/dev/null 2>&1 || true
  fi
}

# ── Per-lineage peer-swap on persistent error ───────────────────────────
# Find the next alive agent of the SAME lineage as the failed agent, swap
# it in, nudge it with the same prompt. Works for any lineage (codex,
# gemini, opencode). Stays on subscription pricing — picks from agents.json
# which the user has set up with their preferred providers.
# Returns 0 if swap performed, 1 otherwise (caller falls back to escalation).
try_lineage_swap() {
  local failed="$1"
  local failed_type="${TYPE[$failed]:-}"
  [ -z "$failed_type" ] && return 1

  # Find candidate replacement: same type, alive tmux session, not already
  # in VALID, not already tried as a swap-target. LRU-ordered (oldest first
  # = least-recently-used = most likely to have quota).
  local candidates
  candidates=$(jq -r --arg t "$failed_type" --arg failed "$failed" '
    .agents[]
    | select(.type == $t and .name != $failed)
    | .name
  ' "$AGENTS_JSON")

  local partner=""
  local c
  for c in $candidates; do
    # Already in VALID? skip (would double-up the lineage)
    local in_valid=0
    local v
    for v in "${VALID[@]}"; do [ "$v" = "$c" ] && in_valid=1; done
    [ "$in_valid" = "1" ] && continue

    # Already tried as a swap target this run? skip
    [ "${SWAPPED_TO[$c]:-0}" = "1" ] && continue

    # tmux session alive?
    local sess_name
    sess_name=$(jq -r --arg n "$c" '.agents[] | select(.name == $n) | .tmux_session' "$AGENTS_JSON")
    tmux has-session -t "$sess_name" 2>/dev/null || continue

    partner="$c"
    break
  done

  [ -z "$partner" ] && return 1

  # Resolve partner metadata
  local row
  row=$(jq -c --arg n "$partner" '.agents[] | select(.name == $n)' "$AGENTS_JSON")
  NUDGE[$partner]=$(jq -r '.nudge_command' <<<"$row")
  ENVVAR[$partner]=$(jq -r '.tmux_env_var' <<<"$row")
  SESS[$partner]=$(jq -r '.tmux_session' <<<"$row")
  TYPE[$partner]=$(jq -r '.type' <<<"$row")

  SWAPPED_TO[$partner]=1
  SWAP_TRIED[$failed]="$partner"
  printf '  ⇄ %-12s %s peer-swap → %s (taking over from failed %s)\n' \
    "$partner" "$failed_type" "$partner" "$failed" >&2
  echo "$failed → $partner: $(date -Iseconds): peer-swap on persistent error ($failed_type lineage)" >> "$out/error-retries.log" 2>/dev/null || true

  # Initialise partner tracking
  LAST_PROMPT[$partner]="${LAST_PROMPT[$failed]}"
  LAST_NUDGE[$partner]="${NUDGE[$partner]}"
  LAST_NUDGE_ENV[$partner]="${ENVVAR[$partner]}"
  ERROR_RETRIED_AT[$partner]=0
  ERROR_GAVE_UP[$partner]=0

  # Initialise findings file
  printf '# Findings — %s\n\n_(swapped in at %s, replacing %s of same %s lineage)_\n' \
    "$partner" "$(date -u -Iseconds)" "$failed" "$failed_type" > "$out/${partner}-findings.md"

  # Add to VALID so the watcher waits for its ## DONE
  VALID+=("$partner")

  # Per-CLI clear: opencode → /new, codex+gemini → /clear (only for opencode
  # since codex/gemini may carry useful context across rounds; the partner
  # being a different account/session means it has no carry-over anyway,
  # but a /clear is cheap insurance).
  case "$failed_type" in
    opencode) tmux send-keys -t "${SESS[$partner]}" "/new" Enter 2>/dev/null || true ; sleep 2 ;;
    *)        tmux send-keys -t "${SESS[$partner]}" "/clear" Enter 2>/dev/null || true ; sleep 1 ;;
  esac
  # Defensive Escape in case partner has its own stale popup (opencode)
  tmux send-keys -t "${SESS[$partner]}" Escape 2>/dev/null || true
  sleep 0.5

  # Nudge partner with the same prompt
  env "${ENVVAR[$partner]}=${SESS[$partner]}" "${NUDGE[$partner]}" "${LAST_PROMPT[$failed]}" >/dev/null 2>&1 || true
  return 0
}

# ── Provider error detection — retry once, then give up ─────────────────
# Catches "Error from provider", rate limits, gateway hiccups, context
# overflow. Without this the watcher waits silently until --timeout (600s).
# Retry policy: 1 attempt, no recurrence handling. If retry succeeds the
# agent writes findings normally; if it errors a 2nd time we stop nudging
# and let the natural timeout mark it incomplete.
check_for_errors() {
  local name="$1"
  local sess="${SESS[$name]:-}"
  [ -z "$sess" ] && return 0
  [ "${ERROR_GAVE_UP[$name]:-0}" = "1" ] && return 0
  local pane
  pane=$(tmux capture-pane -t "$sess" -p 2>/dev/null | tail -30 || true)
  echo "$pane" | grep -qiE "$ERROR_RE" || return 0

  # Skip if pane is also showing findings-being-written content — false
  # positive from the prompt text itself echoing back.
  if tail -3 "$out/${name}-findings.md" 2>/dev/null | grep -qE '^## DONE\s*$'; then
    return 0
  fi

  local now last
  now=$(date +%s)
  last="${ERROR_RETRIED_AT[$name]:-0}"

  if [ "$last" -eq 0 ]; then
    ERROR_RETRIED_AT[$name]=$now
    printf '  ⟳ %-12s provider error detected — retrying nudge (1 attempt)\n' "$name" >&2
    echo "$name: $(date -Iseconds): error detected, retrying" >> "$out/error-retries.log" 2>/dev/null || true
    # Dismiss any modal toast on opencode before re-nudging.
    [ "${TYPE[$name]:-}" = "opencode" ] && tmux send-keys -t "$sess" Escape 2>/dev/null && sleep 1
    env "${LAST_NUDGE_ENV[$name]}=${SESS[$name]}" "${LAST_NUDGE[$name]}" "${LAST_PROMPT[$name]}" >/dev/null 2>&1 || true
  elif [ $((now - last)) -ge 60 ]; then
    ERROR_GAVE_UP[$name]=1
    # First try peer-swap within the same lineage. Works for codex
    # (cdx-1→2→3), gemini (gem-1→2→…), and opencode (kimi⇄deepseek).
    # If a swap succeeds, the failed agent gets a stub-DONE here AND the
    # partner is now reviewing. If no swap candidate is available, escalate.
    if try_lineage_swap "$name"; then
      printf '  ✗ %-12s marked done with stub (peer-swap took over)\n' "$name" >&2
    else
      printf '  ✗ %-12s provider error AGAIN — no swap candidate, escalating to Claude (stub findings written)\n' "$name" >&2
    fi
    echo "$name: $(date -Iseconds): second error, escalating to Claude" >> "$out/error-retries.log" 2>/dev/null || true
    # Escalation: write a stub findings file so the watcher exits its inotify
    # loop now (not after 600s timeout). No <verdict> block → work-converge
    # marks this lineage as missing → decision=incomplete → Claude takes over.
    local first_err_iso
    first_err_iso=$(date -u -d "@$last" -Iseconds 2>/dev/null || date -u -Iseconds)
    cat > "$out/${name}-findings.md" <<STUB
# Findings — $name

> ⚠️ AGENT ESCALATED TO CLAUDE — provider error, auto-retry failed

This reviewer hit a provider error, the orchestrator auto-retried once, and the
retry also errored. The orchestrator has stopped nudging this agent and is
handing the decision back to Claude.

**Timeline:**
- First error detected: $first_err_iso
- Auto-retry sent immediately
- Second error detected: $(date -u -Iseconds)

**Inspect:** \`tmux attach -t ${SESS[$name]}\`
**Full error log:** \`$out/error-retries.log\`

**Claude — choose one:**
1. Manually clear + re-nudge this agent (\`tmux send-keys -t ${SESS[$name]} /clear Enter\`, then re-run the nudge).
2. Swap to a different agent of the same lineage (e.g. kimi ⇄ deepseek for opencode lineage). Re-run \`work review\` with the new \`--agents\` list.
3. Proceed without this lineage — quorum will be \`incomplete\` (exit 2).

(No \`<verdict>\` block intentionally; work-converge classifies this as missing.)

## DONE
STUB
  fi
  # <60s after retry: still in retry-grace window, ignore (TUI may be
  # repainting the previous error frame).
}

cmd_status() {
  # Live snapshot of the most-recent /work run. Replaces ad-hoc
  # "tmux capture-pane -t kimi" + "ls -la /tmp/work-*" gymnastics.
  # Usage: work status [--watch] [--run <out-dir>]
  local watch=0 explicit_run=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --watch)   watch=1; shift ;;
      --run)     explicit_run="$2"; shift 2 ;;
      -h|--help) echo "work status [--watch] [--run <dir>]" >&2; return 0 ;;
      *)         echo "work status: unknown flag $1" >&2; return 2 ;;
    esac
  done

  local run_dir=""
  if [ -n "$explicit_run" ]; then
    run_dir="$explicit_run"
  else
    run_dir=$(ls -dt /tmp/work-*-r*-* 2>/dev/null | head -1 || true)
  fi
  # If no run found, fleet view still renders (just no per-run columns).

  # Compute the colored state string for one agent given pane text + optional
  # findings-file context. Echoes the ANSI-coded state as one line.
  _state_for() {
    local pane="$1"
    local in_run="$2"   # 1 if agent is in current run (has findings file), 0 otherwise
    local done_marker="$3" # ✓ or ✗
    local bytes="$4"
    local elapsed_s="$5"
    local sess_alive="$6"  # 1 if tmux has-session, 0 otherwise

    if [ "$sess_alive" = "0" ]; then
      printf '\033[1;31mDEAD\033[0m (no tmux session)'
      return
    fi
    if [ "$in_run" = "1" ] && [ "$done_marker" = "✓" ]; then
      printf '\033[1;32mDONE\033[0m'
      return
    fi
    if echo "$pane" | grep -qiE 'Error from provider|Provider returned error|rate limit|429 Too Many|503 Service|context (length|window) exceeded'; then
      printf '\033[1;31mERRORED\033[0m'
      return
    fi
    if echo "$pane" | grep -qE 'Select agent|Select model|Select session|^[[:space:]]*Ask[[:space:]]+No results found'; then
      printf '\033[1;33mPOPUP-STUCK\033[0m'
      return
    fi
    if echo "$pane" | grep -qiE 'Allow this|Allow execution|Allow once|Approve this|\(y/N\)|\[y/N\]'; then
      printf '\033[1;33mPERM-PROMPT\033[0m'
      return
    fi
    if echo "$pane" | grep -qE 'esc[ ]+(to[ ]+)?(interrupt|cancel)|Working|Thinking|Generating|Streaming|Processing|Reading|Writing|Sending|Receiving|⬝|⠋|⠙|⠹|⠸|⠼|⠴|⠦|⠧|⠇|⠏|↑↓|interrupt'; then
      printf '\033[1;34mWORKING\033[0m'
      return
    fi
    if [ "$in_run" = "1" ] && [ "$bytes" -gt 200 ]; then
      printf '\033[1;34mWRITING\033[0m'
      return
    fi
    if [ "$in_run" = "1" ] && [ "$elapsed_s" -lt 15 ]; then
      printf '\033[1;34mWORKING\033[0m (just nudged)'
      return
    fi
    if [ "$in_run" = "1" ]; then
      printf '\033[2midle?\033[0m (in run but silent)'
    else
      printf '\033[2midle\033[0m'
    fi
  }

  _format_elapsed() {
    local s="$1"
    if [ "$s" -lt 60 ]; then echo "${s}s"
    elif [ "$s" -lt 3600 ]; then echo "$((s/60))m$((s%60))s"
    else echo "$((s/3600))h$((s/60%60))m"
    fi
  }

  _render_status() {
    local rd="$1"
    local now_iso now
    now_iso=$(date '+%Y-%m-%d %H:%M:%S')
    now=$(date +%s)

    if [ -n "$rd" ] && [ -d "$rd" ]; then
      printf '\033[1;36m▶ %s\033[0m  (refresh: %s)\n\n' "$(basename "$rd")" "$now_iso"
    else
      printf '\033[1;36m▶ Fleet status\033[0m  (refresh: %s)  — no recent run\n\n' "$now_iso"
    fi

    # Header
    printf '  %-12s %-10s %-9s %-6s %-9s %s\n' \
      "AGENT" "TMUX" "ELAPSED" "DONE?" "BYTES" "STATE"
    printf '  %s\n' "------------ ---------- --------- ----- --------- -----"

    # Iterate over ALL agents from agents.json, in priority order.
    # Agents in the current run get full file-derived info; agents not in
    # the run still get a pane-state summary so the user sees the whole fleet.
    local all_agents
    # Sort: type alphabetically (codex → gemini → opencode), then name.
    # Lets the display group lineages together.
    mapfile -t all_agents < <(jq -r '.agents[] | "\(.type)\t\(.name)\t\(.tmux_session)"' "$AGENTS_JSON" | sort -t$'\t' -k1,1 -k2,2)

    local row name session
    local f mtime elapsed_s elapsed_str done_str bytes pane in_run sess_alive state
    for row in "${all_agents[@]}"; do
      # Format is now: type \t name \t session
      name=$(echo "$row" | cut -f2)
      session=$(echo "$row" | cut -f3)
      [ -z "$name" ] && continue

      # tmux session alive?
      if tmux has-session -t "$session" 2>/dev/null; then
        sess_alive=1
        pane=$(tmux capture-pane -t "$session" -p 2>/dev/null | tail -30 || true)
      else
        sess_alive=0
        pane=""
      fi

      # In current run?
      elapsed_s=0
      f="$rd/${name}-findings.md"
      if [ -n "$rd" ] && [ -f "$f" ]; then
        in_run=1
        mtime=$(stat -c %Y "$f" 2>/dev/null || echo "$now")
        elapsed_s=$((now - mtime))
        elapsed_str=$(_format_elapsed "$elapsed_s")
        bytes=$(stat -c %s "$f" 2>/dev/null || echo 0)
        if tail -3 "$f" 2>/dev/null | grep -qE '^## DONE\s*$'; then
          done_str="✓"
        else
          done_str="✗"
        fi
      else
        in_run=0
        elapsed_str="-"
        bytes=0
        done_str="-"
      fi

      state=$(_state_for "$pane" "$in_run" "$done_str" "$bytes" "$elapsed_s" "$sess_alive")

      # Display: bytes column uses '-' instead of 0 when not in run
      local bytes_col="$bytes"
      [ "$in_run" = "0" ] && bytes_col="-"

      printf "  %-12s %-10s %-9s %-6s %-9s %b\n" \
        "$name" "$session" "$elapsed_str" "$done_str" "$bytes_col" "$state"
    done

    # Side-channel logs (only if there's a current run)
    if [ -n "$rd" ] && [ -d "$rd" ]; then
      echo ""
      local n_err n_pop n_dest n_appr
      n_err=$([ -f "$rd/error-retries.log" ] && wc -l < "$rd/error-retries.log" | tr -d ' ' || echo 0)
      n_pop=$([ -f "$rd/popup-dismissals.log" ] && wc -l < "$rd/popup-dismissals.log" | tr -d ' ' || echo 0)
      n_dest=$([ -f "$rd/destructive-blocks.log" ] && wc -l < "$rd/destructive-blocks.log" | tr -d ' ' || echo 0)
      n_appr=$([ -f "$rd/approvals.log" ] && wc -l < "$rd/approvals.log" | tr -d ' ' || echo 0)
      printf '  Logs:  errors=%s  popups=%s  blocks=%s  approvals=%s\n' "$n_err" "$n_pop" "$n_dest" "$n_appr"
    fi
  }

  if [ "$watch" -eq 1 ]; then
    while :; do
      clear
      _render_status "$run_dir"
      sleep 2
    done
  else
    _render_status "$run_dir"
  fi
}

cmd_permissions() {
  # Show recent auto-approvals + destructive blocks across all /work runs.
  # Helps the user spot repeating prompts that should be permanently allowed
  # via the CLI's own config rather than relying on runtime approval.
  local log="$HOME/.work/approvals-global.log"
  local n="${1:-30}"
  echo "▶ Recent auto-approved prompts (last $n)" >&2
  if [ ! -s "$log" ]; then
    echo "  (none yet — log: $log)" >&2
  else
    tail -n "$n" "$log" | column -t -s $'\t'
  fi
  echo >&2
  echo "▶ Repeating commands (top 10) — candidates to allow permanently:" >&2
  if [ -s "$log" ]; then
    cut -f3- "$log" | sort | uniq -c | sort -rn | head -10
  fi
  echo >&2
  echo "▶ Destructive blocks across recent runs:" >&2
  find /tmp -maxdepth 2 -name destructive-blocks.log -mtime -7 2>/dev/null | while read -r f; do
    echo "  $f:" >&2
    sed 's/^/    /' "$f"
  done
  echo >&2
  echo "▶ How to allow permanently (per CLI):" >&2
  cat >&2 <<'HOW'
  • Codex: edit ~/.codex/config.toml — add a [projects."<path>"] block with trust_level = "trusted",
    or under [sandbox] expand allowed shell commands.
  • Gemini: edit ~/.gemini/policies/<name>.toml — add allow rules (mirror the structure of
    00-deny-destructive.toml). Auto-approve mode is set in ~/.gemini/settings.json.
  • Opencode: edit ~/.config/opencode/opencode.json — under "permission", set the tool key to "allow".
    Current keys: read, edit, glob, grep, list, lsp, todowrite, websearch, webfetch, bash, task,
    external_directory, codesearch, skill, question.
HOW
}

# ── Dispatch ─────────────────────────────────────────────────────────────
[ $# -eq 0 ] && { echo "work: usage: work {pick-agents|review|status|state-get|state-set|clean|permissions} ..." >&2; exit 2; }

sub="$1"; shift
case "$sub" in
  pick-agents) cmd_pick_agents "$@" ;;
  review)      cmd_review "$@" ;;
  status)      cmd_status "$@" ;;
  state-get)   cmd_state_get ;;
  state-set)   cmd_state_set "$@" ;;
  clean)       cmd_clean "$@" ;;
  permissions) cmd_permissions "$@" ;;
  -h|--help)
    awk '/^[^#]/{exit} NR>1{sub(/^# ?/,""); print}' "$0"
    exit 0 ;;
  *) echo "work: unknown subcommand '$sub'" >&2; exit 2 ;;
esac
